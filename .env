# Telegram Bot Token (Get from BotFather)
TELEGRAM_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN_HERE

# Google Gemini API Key (For intent routing & extraction)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Qwen API Key (For ASR audio transcription)
QWEN_API_KEY=YOUR_QWEN_API_KEY_HERE

# Security: Telegram User ID whitelist (comma separated if multiple)
# Get your ID from @userinfobot
ADMIN_CHAT_ID=YOUR_TELEGRAM_USER_ID

# ─── 外部系统 API（意图执行） ───
# 日记网域名（待办 + 日记共用，如 https://diary.example.com）
DIARY_DOMAIN=

# 待办任务 API Key（POST /api/external/tasks）
EXTERNAL_TASKS_API_KEY=

# 日记通知 API Key（POST /api/notifications/send，可选，缺省时用 EXTERNAL_TASKS_API_KEY）
# DIARY_API_KEY=

# 财务网域名（GET /api/finance/ai-context）
FINANCE_DOMAIN=

# 财务 AI 上下文 API Key
AI_CONTEXT_API_KEY=

